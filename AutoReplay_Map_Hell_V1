-- ║               MAIN LOOP - AUTO REPLAY                    ║
-- ╚══════════════════════════════════════════════════════════╝
task.spawn(function()
    syncReplayRunning() 
    while isRunning and ScreenGui and ScreenGui.Parent do
        task.wait(ReplayConfig.LoopInterval)

        local ok, err = pcall(function()
            if not replayRunning then return end
            local now = os.clock()

            -- PRIORITAS 1: GameEnd / Play Again
            local againBtn, gameEnd = getAgainButton()
            if gameEnd and gameEnd.Visible == true then
                if not ReplayConfig.Playagain then
                    setReplayStatus("GameEnd visible, tapi Playagain=OFF -> klik manual.")
                    return
                end
                if (now - lastAgainAt) < ReplayConfig.CooldownAgain then return end
                if not againBtn then
                    setReplayStatus("GameEnd visible tapi tombol Again belum ready...")
                    return
                end

                clickAttempt = clickAttempt + 1
                if clickAttempt > 3 then clickAttempt = 1 end

                setReplayStatus(string.format("Klik Play Again (method %d)...", clickAttempt))
                dprint("Klik Play Again, attempt =", clickAttempt)

                virtualClick(againBtn, clickAttempt)
                lastAgainAt = os.clock()

                task.wait(ReplayConfig.ClickVerifyT)
                local _, geAfter = getAgainButton()
                if (not geAfter) or (geAfter.Visible == false) then
                    setReplayStatus("Play Again berhasil di-klik!")
                    clickAttempt = 0
                else
                    setReplayStatus(string.format("Klik gagal (method %d), retry method berikutnya...", clickAttempt))
                end
                return
            end

            -- PRIORITAS 2: DifficultyVote
            local _, difVote = getDifficultyButtonByName(ReplayConfig.TargetDif)
            if difVote and difVote.Visible == true then
                
                -- LOGIKA V10: Cek Follow Vote dulu secara mandiri (terlepas dari AutoStart)
                if FollowVoteConfig.FollowUserVote then
                    local followedVote = getFollowedVoteDifficulty()
                    if followedVote then
                        if (now - lastVoteAt) < ReplayConfig.CooldownVote then return end
                        
                        setReplayStatus("[FOLLOW] KETEMU! Mengikuti vote user lain -> " .. followedVote)
                        local difBtn = getDifficultyButtonByName(followedVote)
                        if difBtn then
                            virtualClick(difBtn, 1)
                            task.wait(0.25)
                        end

                        invokeRemote("PlaceDifficultyVote", followedVote)
                        task.wait(0.4)
                        local restartOk = invokeRemote("RestartGame")
                        lastVoteAt = os.clock()

                        if restartOk then
                            lastVotedDif = followedVote
                            refreshCounterUI()
                        end

                        setReplayStatus("RestartGame fired (" .. followedVote .. "). Tunggu match...")
                        task.wait(1)
                        return
                    else
                        setReplayStatus("Memantau... Menunggu target user untuk vote.")
                        return 
                    end
                end

                if not ReplayConfig.AutoStart then
                    setReplayStatus("DifficultyVote muncul, tapi AutoStart/Follow=OFF -> pilih manual.")
                    return
                end

                if (now - lastVoteAt) < ReplayConfig.CooldownVote then return end

                local chosenDif, isRandom = decideNextDif()
                if isRandom then
                    setReplayStatus("[RANDOM #" .. (gameplayCount + 1) .. "] Vote " .. chosenDif .. " + RestartGame...")
                    lastRandomDif = chosenDif
                else
                    setReplayStatus("Vote " .. chosenDif .. " + RestartGame...")
                end

                local difBtn = getDifficultyButtonByName(chosenDif)
                if not difBtn and chosenDif ~= ReplayConfig.TargetDif then
                    dprint("Button " .. chosenDif .. " tidak ditemukan, fallback ke " .. ReplayConfig.TargetDif)
                    chosenDif = ReplayConfig.TargetDif
                    isRandom  = false
                    difBtn    = getDifficultyButtonByName(chosenDif)
                end

                if difBtn then
                    virtualClick(difBtn, 1)
                    task.wait(0.25)
                end

                invokeRemote("PlaceDifficultyVote", chosenDif)
                task.wait(0.4)
                local restartOk = invokeRemote("RestartGame")

                lastVoteAt = os.clock()

                if restartOk then
                    lastVotedDif = chosenDif
                    refreshCounterUI()
                end

                setReplayStatus("RestartGame fired (" .. chosenDif .. "). Tunggu match-detection naikin counter...")
                task.wait(1)
                return
            end

            -- IDLE
            setReplayStatus("Running... (menunggu GameEnd / DifficultyVote)")
        end)
        if not ok then
            dprint("Iterasi Replay error:", err)
            setReplayStatus("Error: " .. tostring(err))
        end
    end
end)

