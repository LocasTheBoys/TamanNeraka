-- ║         MATCH-DETECTION LOOP (counter game #N)           ║
-- ╚══════════════════════════════════════════════════════════╝
task.spawn(function()
    while isRunning and ScreenGui and ScreenGui.Parent do
        task.wait(LOOP_INTERVAL_TRACKER)
        if not isRunning then break end

        local ok, err = pcall(function()
            local timerText  = getInGameTimer()
            local currentSec = parseMMSS(timerText)

            local gameEnd    = getGameEnd()
            local isGameOver = (gameEnd and gameEnd.Visible == true) or false

            local isLobby = (currentSec == nil or currentSec < 2)

            if isGameOver or isLobby then
                if isMatchRunning then
                    isMatchRunning = false
                    if highestSecThisMatch > 10 then
                        gameplayCount = gameplayCount + 1
                        lastMatchSec  = highestSecThisMatch
                        refreshCounterUI()
                        dprint("Match END detected. gameplayCount =", gameplayCount, "highestSec =", highestSecThisMatch)
                    else
                        dprint("Match END diabaikan (highestSec <=10):", highestSecThisMatch)
                    end
                    localMatchSec       = 0
                    highestSecThisMatch = 0
                end
                cachedTimerLabel = nil
            else
                if not isMatchRunning then
                    if gameplayCount == 0 or (currentSec and currentSec < 15) then
                        isMatchRunning = true
                        dprint("Match START detected. timer =", currentSec)
                    end
                end

                if isMatchRunning and currentSec then
                    if currentSec == 3599 and highestSecThisMatch > 0 and highestSecThisMatch < 3500 then
                        -- skip glitch
                    else
                        localMatchSec = currentSec
                        if currentSec > highestSecThisMatch then
                            highestSecThisMatch = currentSec
                        end
                    end
                end
            end
        end)
        if not ok then dprint("Tracker iterasi error:", err) end
    end
end)

