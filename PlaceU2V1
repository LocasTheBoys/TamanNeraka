local function tryDirectTimerPath(pGui)
    local tbs  = pGui  and pGui:FindFirstChild("TopbarStandard")
    local hold = tbs   and tbs:FindFirstChild("Holders")
    local rgt  = hold  and hold:FindFirstChild("Right")
    if not rgt then return nil, nil, "DIRECT(no-holder-right)" end

    local requireClock = (CONFIG.TIMER_REQUIRE_CLOCK_EMOJI ~= false)
    local bestSec, bestText, bestName, bestScore = nil, nil, nil, -1
    local bestLabel, bestWidget = nil, nil
    for _, widget in ipairs(rgt:GetChildren()) do
        local ib   = widget:FindFirstChild("IconButton")
        local menu = ib    and ib:FindFirstChild("Menu")
        local spot = menu  and menu:FindFirstChild("IconSpot")
        local cnt  = spot  and spot:FindFirstChild("Contents")
        local cont = cnt   and cnt:FindFirstChild("IconLabelContainer")
        local lbl  = cont  and cont:FindFirstChild("IconLabel")
        if lbl and lbl.Text and lbl.Text ~= "" then
            local sec = parseMMSS(lbl.Text)
            if sec and (not requireClock or hasClockEmoji(lbl.Text)) then
                local score = 1
                if hasClockEmoji(lbl.Text) then score = score + 10 end
                local lname = string.lower(widget.Name or "")
                if string.find(lname, "time", 1, true)
                   or string.find(lname, "timer", 1, true)
                   or string.find(lname, "wave", 1, true) then
                    score = score + 2
                end
                if score > bestScore then
                    bestSec    = sec
                    bestText   = lbl.Text
                    bestName   = widget.Name
                    bestScore  = score
                    bestLabel  = lbl
                    bestWidget = widget
                end
            end
        end
    end

    if bestSec then
        if CONFIG.TIMER_USE_WIDGET_CACHE ~= false then
            local wasFirstLock = (cachedTimerLabel == nil)
            cachedTimerLabel  = bestLabel
            cachedTimerWidget = bestWidget
            cachedTimerName   = tostring(bestName)
            timerEverFound    = true
        end
        return bestSec, bestText, "WIDGET:" .. tostring(bestName)
    end
    if requireClock then return nil, nil, "DIRECT(no-clock-widget)" end
    return nil, nil, "DIRECT(no-mm:ss)"
end

local function findTimerLabel(root, depth)
    depth = depth or 0
    if depth > 10 then return nil end
    local requireClock = (CONFIG.TIMER_REQUIRE_CLOCK_EMOJI ~= false)
    local best, bestScore = nil, -1
    local ok, children = pcall(function() return root:GetChildren() end)
    if not ok or not children then return nil end
    for _, c in ipairs(children) do
        local pass, isText = pcall(function() return c:IsA("TextLabel") end)
        if pass and isText and c.Text and c.Text ~= "" then
            local sec = parseMMSS(c.Text)
            if sec and (not requireClock or hasClockEmoji(c.Text)) then
                local score = 0
                if c.Name == "IconLabel" then score = score + 5 end
                local fn = ""
                pcall(function() fn = c:GetFullName() end)
                if string.find(fn, "Topbar", 1, true) then score = score + 3 end
                if string.find(fn, "Widget", 1, true) then score = score + 1 end
                if hasClockEmoji(c.Text) then score = score + 10 end
                if score > bestScore then best, bestScore = c, score end
            end
        end
        local childBest = findTimerLabel(c, depth + 1)
        if childBest then
            local sec = parseMMSS(childBest.Text)
            if sec and (not requireClock or hasClockEmoji(childBest.Text)) then
                local score = 0
                if childBest.Name == "IconLabel" then score = score + 5 end
                local fn = ""
                pcall(function() fn = childBest:GetFullName() end)
                if string.find(fn, "Topbar", 1, true) then score = score + 3 end
                if string.find(fn, "Widget", 1, true) then score = score + 1 end
                if hasClockEmoji(childBest.Text) then score = score + 10 end
                if score > bestScore then best, bestScore = childBest, score end
            end
        end
    end
    return best
end

