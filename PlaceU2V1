    initSlotState()
    placementUnlocked     = false
    unlockSource          = "-"
    lastWaveNum           = -1
    maxWaveSeen           = -1
    placementsSinceUnlock = 0
    if CONFIG.TIMER_PERSIST_CACHE_ACROSS_RESET == false then
        invalidateTimerCache()
        timerEverFound = false
    end
    lastTimerSec = -1
    lastTimerRaw = "-"
    lastResetAt  = os.clock()
    pausedUntil  = os.clock() + CONFIG.RESET_COOLDOWN
    currentPhase = "reset (cooldown)"
    pendingReset = false
    lastResult   = string.format("RESET game #%d: %s", gameCount, tostring(reason))
    lastSellWaveSeen = -1
    pcall(resetAutoSellState)

    -- [FIX] Reset match state agar game baru terdeteksi dengan benar
    isMatchRunning      = false
    highestSecThisMatch = 0
    matchEndSince       = 0

    -- bootCompleted TIDAK di-reset. Setelah game pertama ia selalu true.
    -- Ini yang mengaktifkan mid-game fallback di processTimerSnapshot setiap reset.
    needBootSequence  = true
    -- Reset isRunning ke true agar tidak stuck PAUSED setelah game selesai.
    -- Tidak panggil setScriptState() karena fungsi itu belum defined saat ini.
    isRunning = true

    print(string.format("[AutoPlaceV8] === RESET === game #%d | reason: %s | timer-cache=%s",
        gameCount, tostring(reason),
        (cachedTimerLabel and ("KEEP("..tostring(cachedTimerName)..")") or "none")))
end


