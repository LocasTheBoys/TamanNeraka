local function pickRotationDeg()
    local m = CONFIG.ROTATION_MODE
    if m == "off"    then return 0 end
    if m == "fixed"  then return CONFIG.FIXED_ROT_DEG or 0 end
    if m == "smooth" then return randFloat(0, 360) end
    local steps = { 0, 90, 180, 270 }
    return steps[randInt(1, 4)]
end

-- PARSER CERDAS: Membaca 14 Angka (PathIndex, Distance, PosX, PosY, PosZ, Matrix CFrame...)
local function parseFlatToDict(flatArray)
    local pathIdx = flatArray[1]
    local dist    = flatArray[2]
    local pos     = Vector3.new(flatArray[3], flatArray[4], flatArray[5])
    local cf      = CFrame.new(
        flatArray[3], flatArray[4], flatArray[5],
        flatArray[6], flatArray[7], flatArray[8],
        flatArray[9], flatArray[10], flatArray[11],
        flatArray[12], flatArray[13], flatArray[14]
    )
    return {
        Valid = true,
        PathIndex = pathIdx,
        DistanceAlongPath = dist,
        Position = pos,
        CF = cf,
        Rotation = 180 -- Akan ditimpa oleh anti-macro nantinya
    }
end

-- Menerima flat data (14 angka) -> Dictionary -> Anti Macro -> Format Anti Cheat
local function buildArgs(slotDataRaw)
    local slotData = parseFlatToDict(slotDataRaw)

    -- 1. Hitung goyangan acak (Position Offset)
    local off = CONFIG.POSITION_OFFSET or 0
    local dx, dz = 0, 0
    if off > 0 then 
        dx = randFloat(-off, off)
        dz = randFloat(-off, off) 
    end
    
    -- 2. Terapkan goyangan ke posisi asli
    local finalPos = Vector3.new(
        slotData.Position.X + dx, 
        slotData.Position.Y, 
        slotData.Position.Z + dz
    )
    
    -- 3. Hitung rotasi acak
    local rotDeg = pickRotationDeg()
    if CONFIG.ROTATION_MODE == "off" and slotData.Rotation then
        rotDeg = slotData.Rotation
    end
    
    -- 4. Rekonstruksi ulang matrix CF (CFrame) secara matematis!
    local finalCF = CFrame.new(finalPos) * CFrame.Angles(0, math.rad(rotDeg), 0)
    
    -- 5. Susun data rapi sesuai format ketat server game
    local placeData = {
        Valid = slotData.Valid,
        PathIndex = slotData.PathIndex,
        DistanceAlongPath = slotData.DistanceAlongPath,
        Position = finalPos,
        CF = finalCF,
        Rotation = rotDeg
    }
    
    local args = {
        CONFIG.TARGET_UNIT,
        placeData
    }
    
    return args, rotDeg
end


local placeUnitRemote
local function getPlaceUnitRemote()
    if placeUnitRemote and placeUnitRemote.Parent then return placeUnitRemote end
    local rf = ReplicatedStorage:FindFirstChild("RemoteFunctions")
    if rf then placeUnitRemote = rf:FindFirstChild("PlaceUnit") end
    return placeUnitRemote
