_AUTOSELL.index       = _AUTOSELL.index       or {}
_AUTOSELL.triggered   = _AUTOSELL.triggered   or {}
_AUTOSELL.countAll    = _AUTOSELL.countAll    or 0
_AUTOSELL.countUnit   = _AUTOSELL.countUnit   or 0
_AUTOSELL.lastSummary = _AUTOSELL.lastSummary or "-"

function _AUTOSELL.register(unitId, unitName, src)
    if type(unitId) ~= "number" or unitId <= 0 then return end
    local existing = _AUTOSELL.index[unitId]
    if existing then
        if unitName and not existing.unitName then existing.unitName = unitName end
        return
    end
    _AUTOSELL.index[unitId] = {
        unitName = unitName,
        src      = src or "?",
        ts       = os.clock(),
    }
end

function _AUTOSELL.unregister(unitId)
    if _AUTOSELL.index[unitId] ~= nil then
        _AUTOSELL.index[unitId] = nil
    end
end

function _AUTOSELL.scanWorkspace()
    pcall(function()
        local map = workspace:FindFirstChild("Map")
        local ent = map and map:FindFirstChild("Entities")
        if ent then
            for _, entity in ipairs(ent:GetChildren()) do
                local nm = entity.Name
                if type(nm) == "string" and startsWith(nm, "unit_") then
                    local id = entity:GetAttribute("ID") or entity:GetAttribute("Id") or entity:GetAttribute("UnitId")
                    if id and type(id) == "number" then
                        _AUTOSELL.register(id, nm, "WS")
                    end
                end
            end
        end
    end)
end

function _AUTOSELL.refreshIndex()
    _AUTOSELL.index = {}
    _AUTOSELL.scanWorkspace()
end

function _AUTOSELL.rfFolder()
    return ReplicatedStorage:FindFirstChild("RemoteFunctions")
end

function _AUTOSELL.getSellAllRemote()
    local rf = _AUTOSELL.rfFolder()
    return rf and rf:FindFirstChild(CONFIG.SELL_REMOTE_NAME_ALL or "SellAll") or nil
end

function _AUTOSELL.getSellUnitRemote()
    local rf = _AUTOSELL.rfFolder()
    return rf and rf:FindFirstChild(CONFIG.SELL_REMOTE_NAME_ONE or "SellUnit") or nil
end

function _AUTOSELL.buildIdList()
    local wantSet = {}
    if type(CONFIG.SELL_TARGET_UNITS) == "table" and #CONFIG.SELL_TARGET_UNITS > 0 then
        for _, n in ipairs(CONFIG.SELL_TARGET_UNITS) do
            if type(n) == "string" and #n > 0 then wantSet[n] = true end
        end
    elseif CONFIG.TARGET_UNIT then
        wantSet[CONFIG.TARGET_UNIT] = true
    end
    local list = {}
    for id, info in pairs(_AUTOSELL.index) do
        local nm = info.unitName
        if nm and wantSet[nm] then
            table.insert(list, id)
        end
    end
    return list, wantSet
end

local function shuffleTable(t)
    for i = #t, 2, -1 do
        local j = math.random(1, i)
        t[i], t[j] = t[j], t[i]
    end
end

function _AUTOSELL.sellAll()
    local remote = _AUTOSELL.getSellAllRemote()
    if not remote then
        warn("[AutoSellV8-OPT] SellAll remote tidak ditemukan di RemoteFunctions.")
        _AUTOSELL.lastSummary = "FAIL: remote SellAll tidak ada"
        return false, "no-remote"
    end
    local before = lastUIAllUnits
    local ok, ret = pcall(function() return remote:InvokeServer() end)
    _AUTOSELL.countAll = _AUTOSELL.countAll + 1
    local success = isSuccessReturn(ok, ret)
    if success then
        _AUTOSELL.index = {}
    end
    _AUTOSELL.lastSummary = string.format("SellAll @W%d (count=%d)",
        lastWaveNum or -1, _AUTOSELL.countAll)
    return success, ret
end

function _AUTOSELL.sellTarget()
    local remote = _AUTOSELL.getSellUnitRemote()
    if not remote then
        warn("[AutoSellV8-OPT] SellUnit remote tidak ditemukan di RemoteFunctions.")
        _AUTOSELL.lastSummary = "FAIL: remote SellUnit tidak ada"
        return false, "no-remote"
    end
    
    _AUTOSELL.refreshIndex()
    local idList, wantSet = _AUTOSELL.buildIdList()
    
    if #idList == 0 then
        _AUTOSELL.lastSummary = string.format("SellTarget @W%d: 0 ID found", lastWaveNum or -1)
        warn("[AutoSellV8-OPT] Tidak ada UnitId yg match list -> sell di-skip.")
        return false, "no-id"
    end

    shuffleTable(idList)

    local okCount, failCount = 0, 0
    for _, id in ipairs(idList) do
        local triesLeft = (CONFIG.SELL_RETRY_AFTER_FAIL or 0) + 1
        local sold = false
        while triesLeft > 0 and not sold do
            triesLeft = triesLeft - 1
            local ok, ret = pcall(function()
                return remote:InvokeServer(id)
            end)
            local success = isSuccessReturn(ok, ret)
            if success then
                sold = true
                okCount = okCount + 1
                _AUTOSELL.countUnit = _AUTOSELL.countUnit + 1
                _AUTOSELL.unregister(id)
            else
                if triesLeft > 0 then
                    task.wait(randFloat(CONFIG.SELL_DELAY_MIN or 0.3, CONFIG.SELL_DELAY_MAX or 0.8))
                end
            end
        end
        if not sold then failCount = failCount + 1 end
        task.wait(randFloat(CONFIG.SELL_DELAY_MIN or 0.3, CONFIG.SELL_DELAY_MAX or 0.8))
    end
    _AUTOSELL.lastSummary = string.format("SellTarget @W%d ok=%d fail=%d (total ok=%d)",
        lastWaveNum or -1, okCount, failCount, _AUTOSELL.countUnit)
    return (okCount > 0), { ok = okCount, fail = failCount }
end

function _AUTOSELL.maybeTrigger(newWave)
    if not CONFIG.AUTO_SELL_ENABLED then return end
    if type(newWave) ~= "number" then return end

    local pauseSec = CONFIG.SELL_PAUSE_PLACEMENT_SEC or 0
    local function applyPause(reason)
        if pauseSec > 0 then
            pausedUntil = math.max(pausedUntil, os.clock() + pauseSec)
        end
    end

    local sa = CONFIG.SELL_ALL_AT_WAVE or 0
    if sa > 0 and newWave == sa and not _AUTOSELL.triggered[("ALL_"..sa)] then
        _AUTOSELL.triggered[("ALL_"..sa)] = true
        print(string.format("[AutoSellV8-OPT] >>> Wave %d reached -> trigger SELL ALL <<<", newWave))
        task.spawn(function()
            local initDelay = randFloat(CONFIG.SELL_INITIAL_DELAY_MIN or 1.5, CONFIG.SELL_INITIAL_DELAY_MAX or 4.5)
            task.wait(initDelay)
            applyPause("SellAll")
            pcall(_AUTOSELL.sellAll)
        end)
    end

    local st = CONFIG.SELL_TARGET_AT_WAVE or 0
    if st > 0 and newWave == st and not _AUTOSELL.triggered[("TGT_"..st)] then
        _AUTOSELL.triggered[("TGT_"..st)] = true
        print(string.format("[AutoSellV8-OPT] >>> Wave %d reached -> trigger SELL TARGET <<<", newWave))
        task.spawn(function()
            local initDelay = randFloat(CONFIG.SELL_INITIAL_DELAY_MIN or 1.5, CONFIG.SELL_INITIAL_DELAY_MAX or 4.5)
            task.wait(initDelay)
            applyPause("SellTarget")
            pcall(_AUTOSELL.sellTarget)
        end)
    end
end

