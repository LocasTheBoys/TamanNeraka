local isMatchRunning      = false      
local highestSecThisMatch = 0          
local matchEndSince       = 0          
local lastMatchEndAt      = 0          

local function readGameEndVisible()
    local visible = false
    pcall(function()
        local pGui    = LocalPlayer:FindFirstChild("PlayerGui")
        local gameGui = pGui    and pGui:FindFirstChild("GameGui")
