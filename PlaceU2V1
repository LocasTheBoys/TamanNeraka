local function hasGivenUpPriority()
    if not CONFIG.PRIORITY_LOCK then return false end
    for i = 1, #SLOTS_PRIORITY do
        if not prioritySatisfied[i]
           and (priorityGivenUp[i] or priorityAttempts[i] >= CONFIG.PRIORITY_MAX_TRIES) then
            return true
        end
    end
    return false
end

local function recoverGiveupPrioritySlots()
    local sec = CONFIG.PRIORITY_RETRY_AFTER_GIVEUP_SEC or 0
    if sec <= 0 then return end
    local maxCycles = CONFIG.PRIORITY_MAX_GIVEUP_RETRIES or 0
    local now = os.clock()
    for i = 1, #SLOTS_PRIORITY do
        if priorityGivenUp[i] and not prioritySatisfied[i] then
            if (now - (priorityGiveupSince[i] or 0)) >= sec
               and not (maxCycles > 0 and (priorityGiveupCycles[i] or 0) >= maxCycles) then
                priorityGiveupCycles[i] = (priorityGiveupCycles[i] or 0) + 1
                priorityGivenUp[i]      = false
                priorityAttempts[i]     = 0
                priorityGiveupSince[i]  = 0
            end
        end
    end
end


local function parseMMSS(t)
    if type(t) ~= "string" then return nil end
    if string.find(t, ":", 1, true) then
        local m, s = string.match(t, "(%d+)%s*:%s*(%d+)")
        if m and s then
            local mm = tonumber(m) or 0
            local ss = tonumber(s) or 0
            if ss <= 99 then return mm * 60 + ss end
        end
        return nil
    end
    local n = string.match(t, "(%d+)")
    if n then
        local v = tonumber(n)
        if v and v >= 0 and v <= 99 then return v end
    end
    return nil
end

local function hasClockEmoji(t)
    if type(t) ~= "string" then return false end
    return string.find(t, "⏱", 1, true) ~= nil
end

