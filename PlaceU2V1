-- [FIX] Fungsi boot sequence yang bisa dipanggil ulang setiap game baru
local function runBootSequence()
    if CONFIG.WAVE_CONTROL and CONFIG.REQUIRE_PLACEMENT_GATE then
        setBanner("WAIT TIMER@1s atau Vote UI ...",
            Color3.fromRGB(255, 200, 100))
        local startT = os.clock()
        while not placementUnlocked
              and isAlive()
              and (os.clock() - startT) < CONFIG.WAVE_BOOT_TIMEOUT do
            local sec, traw, tsrc = readTimerOnce()
            processTimerSnapshot(sec, traw, tsrc)
            pcall(updateMatchState, sec)            
            local num, raw = readWaveOnce()
            processWaveSnapshot(num, raw)
            
            -- [TRIGGER 1 Fallback] Mengecek Vote UI saat boot time
            local voteText = readDifficultyVoteOnce()
            if voteText and string.find(string.lower(voteText), "choose level") then
                placementUnlocked = true
                placementsSinceUnlock = 0
                unlockSource = "VOTE_UI [" .. voteText .. "]"
                print("[AutoPlaceV8] " .. unlockSource .. " -> BERSIAP NGEGAS!")
            end
            
            refreshStats()
            task.wait(0.03)
        end
    end
    bootCompleted    = true
    needBootSequence = false
    print(string.format("[AutoPlaceV8] Boot sequence selesai (game #%d, unlocked=%s, src=%s)",
        gameCount, tostring(placementUnlocked), tostring(unlockSource)))
end

