-- ║       HELPER: TRIGGER REJOIN DENGAN UPDATE STATUS         ║
-- ╚══════════════════════════════════════════════════════════╝
local function doRejoinAndUpdateStatus(triggerLabel)
    StatusLabel.Text = (triggerLabel or "Klik") .. "..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    local ok, msg = executeRejoin()
    StatusLabel.Text = (ok and "OK: " or "FAIL: ") .. tostring(msg)
    StatusLabel.TextColor3 = ok and Color3.fromRGB(85, 255, 127) or Color3.fromRGB(255, 85, 85)
    return ok, msg
end


