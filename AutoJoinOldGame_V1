-- ║       VIRTUAL CLICK 3-METHOD (port dari V3)               ║
-- ╚══════════════════════════════════════════════════════════╝
local function clickViaConnections(button)
    if typeof(getconnections) ~= "function" then return false end
    local fired = false
    local signals = { "MouseButton1Click", "Activated", "MouseButton1Down", "MouseButton1Up" }
    for _, sig in ipairs(signals) do
        pcall(function()
            local ev = button[sig]
            if ev then
                local conns = getconnections(ev)
                if conns then
                    for _, c in ipairs(conns) do
                        local ok = pcall(function() c:Fire() end)
                        if not ok and typeof(firesignal) == "function" then
                            pcall(function() firesignal(c) end)
                        end
                        fired = true
                    end
                end
            end
        end)
    end
    return fired
end

local function clickViaFiresignal(button)
    if typeof(firesignal) ~= "function" then return false end
    local signals = { "MouseButton1Down", "MouseButton1Up", "MouseButton1Click", "Activated" }
    local fired = false
    for _, sig in ipairs(signals) do
        pcall(function()
            if button[sig] then
                firesignal(button[sig])
                fired = true
            end
        end)
    end
    return fired
end

local function clickViaVIM(button)
    if not ClickConfig.AllowVIM then return false end
    if not VirtualInputManager then return false end
    local ok = pcall(function()
        local pos  = button.AbsolutePosition
        local size = button.AbsoluteSize
        local x = pos.X + size.X / 2
        local y = pos.Y + size.Y / 2
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, true,  game, 0)
        task.wait(0.07)
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end)
    return ok
end

local function virtualClick(button, attempt)
    if not button then return end
    attempt = attempt or 1

    local targets = { button }
    if ClickConfig.ClickTitleChild then
        local title = button:FindFirstChild("Title")
        if title and (title:IsA("TextLabel") or title:IsA("ImageLabel")
                      or title:IsA("TextButton") or title:IsA("ImageButton")) then
            table.insert(targets, title)
        end
    end

    for _, t in ipairs(targets) do
        if attempt == 1 then
            clickViaConnections(t)
            clickViaFiresignal(t)
        elseif attempt == 2 then
            clickViaFiresignal(t)
            clickViaVIM(t)
        else
            clickViaVIM(t)
            clickViaConnections(t)
            clickViaFiresignal(t)
        end
    end
end


-- ╔══════════════════════════════════════════════════════════╗
-- ║              AKSES TOMBOL VIA PATH PASTI (V3)             ║
-- ╚══════════════════════════════════════════════════════════╝
local function getAcceptButton(notifFrame)
    if not notifFrame or not notifFrame.Parent then return nil, "notifFrame hilang" end
    local options = notifFrame:WaitForChild(PathConfig.OptionsChildName, PathConfig.AcceptWaitTimeout)
    if not options then return nil, "Options frame tidak muncul" end
    local accept = options:WaitForChild(PathConfig.AcceptChildName, PathConfig.AcceptWaitTimeout)
    if not accept then return nil, "Tombol Accept tidak muncul" end
    return accept, nil
end


-- ╔══════════════════════════════════════════════════════════╗
-- ║                    EKSEKUSI REJOIN (V3)                   ║
-- ╚══════════════════════════════════════════════════════════╝
local function executeRejoin()
    if not currentFoundUUID or currentFoundUUID == "" then
        return false, "UUID kosong"
    end
    dprint("Rejoin dipicu. UUID:", currentFoundUUID)

    local clickedViaGui = false
    local guiErrMsg

    if currentFoundFrame and currentFoundFrame.Parent then
        local accept, err = getAcceptButton(currentFoundFrame)
        if accept then
            dprint("Tombol Rejoin ketemu:", accept:GetFullName())

            if ClickConfig.AlsoClickNotifFrame then
                pcall(function() virtualClick(currentFoundFrame, 1) end)
                task.wait(0.05)
            end

            for i = 1, ClickConfig.ClickRetry do
                virtualClick(accept, i)
                clickedViaGui = true
                if i < ClickConfig.ClickRetry then task.wait(ClickConfig.ClickGap) end
                if not (currentFoundFrame and currentFoundFrame.Parent) then break end
                if not accept.Parent then break end
            end
        else
            guiErrMsg = err or "Tombol tidak ditemukan"
            dprint("GUI klik gagal:", guiErrMsg)
        end
    else
        guiErrMsg = "Notif frame sudah hilang"
        dprint(guiErrMsg)
    end

    if not clickedViaGui and RemoteConfig.Enabled then
        local reEvent = ReplicatedStorage:FindFirstChild(RemoteConfig.EventName)
        if reEvent then
            local ok = pcall(function()
                reEvent:FireServer(RemoteConfig.ActionId, currentFoundUUID, RemoteConfig.AcceptOption)
            end)
            if ok then
                dprint("Fallback FireServer terkirim.")
                return true, "Fallback FireServer terkirim"
            else
                return false, "FireServer error"
            end
        else
            return false, RemoteConfig.EventName .. " tidak ada"
        end
    end

    if clickedViaGui then return true, "Klik GUI Accept terkirim (3-method)" end
    return false, guiErrMsg or "Tidak ada aksi"
end


