-- ║         CONFIRM NOTIFIKASI (FIX BUG #1 & #2)              ║
-- ╚══════════════════════════════════════════════════════════╝
-- Begitu confirm = simpen UUID/Frame, lalu kalau auto ON ->
-- langsung klik. Loop passive watcher akan handle retry-nya.
local function confirmAndMaybeAutoRejoin(child)
    if not isCurrent() then return end

    currentFoundUUID  = child.Name
    currentFoundFrame = child

    print("========================================")
    print("[AutoJoinOldGameV5] Notifikasi rejoin terdeteksi!")
    print("[AutoJoinOldGameV5] UUID :", tostring(currentFoundUUID))
    print("[AutoJoinOldGameV5] Path :", child:GetFullName())
    print("========================================")

    if isAutoRejoinActive then
        doRejoinAndUpdateStatus("Auto klik")
    else
        StatusLabel.Text = "Notif siap! Tekan Manual atau ON."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 170, 0)
    end
end


-- ╔══════════════════════════════════════════════════════════╗
-- ║   HANDLE NOTIFIKASI (BARU di V5 - tahan race Label.Text)  ║
-- ╚══════════════════════════════════════════════════════════╝
-- Strategi:
--   1) WaitForChild("Label") sampai LabelWaitTimeout.
--   2) Kalau Label.Text udah pas -> confirm.
--   3) Kalau belum -> pasang GetPropertyChangedSignal("Text"),
--      tunggu sampai Text-nya berubah jadi MatchLabelText
--      (max LabelTextWaitTimeout). Kalau cocok -> confirm.
--   4) Kalau timeout -> abaikan.
local function handleNotification(child)
    if not isCurrent() then return end
    if not child or not child:IsA("GuiObject") then return end

    local label = child:WaitForChild(PathConfig.LabelChildName, PathConfig.LabelWaitTimeout)
    if not label then return end
    if not label:IsA("TextLabel") then return end

    if label.Text == PathConfig.MatchLabelText then
        confirmAndMaybeAutoRejoin(child)
        return
    end

    -- Watcher Text (FIX BUG #1)
    local fired = false
    local conn
    conn = label:GetPropertyChangedSignal("Text"):Connect(function()
        if fired then return end
        if not isCurrent() then if conn then conn:Disconnect() end return end
        if label.Text == PathConfig.MatchLabelText then
            fired = true
            if conn then conn:Disconnect() end
            confirmAndMaybeAutoRejoin(child)
        end
    end)

    -- Cleanup kalau notif udah ke-destroy duluan / timeout
    task.spawn(function()
        local t = 0
        while not fired and isCurrent() and child.Parent and t < PathConfig.LabelTextWaitTimeout do
            task.wait(0.25)
            t = t + 0.25
        end
        if not fired and conn then conn:Disconnect() end
    end)
end


-- ╔══════════════════════════════════════════════════════════╗
-- ║            SETUP DETEKSI + PASSIVE RETRY LOOP             ║
-- ╚══════════════════════════════════════════════════════════╝
local function setupDetection()
    local notifyFolder = PlayerGui:WaitForChild(PathConfig.NotifyFolderName, PathConfig.NotifyFolderTimeout)
    if not notifyFolder then
        warn("[AutoJoinOldGameV5] Timeout: " .. PathConfig.NotifyFolderName .. " tidak ditemukan!")
        StatusLabel.Text = "Gagal menemukan folder notif."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 85, 85)
        return
    end

    -- Anak yg sudah ada
    for _, child in ipairs(notifyFolder:GetChildren()) do
        task.spawn(handleNotification, child)
    end

    -- Listener anak baru
    autoRejoinConnection = notifyFolder.ChildAdded:Connect(function(child)
        if not isCurrent() then
            if autoRejoinConnection then autoRejoinConnection:Disconnect() end
            return
        end
        task.spawn(handleNotification, child)
    end)

    -- Listener anak hilang -> reset state biar gak nyangkut
    notifyFolder.ChildRemoved:Connect(function(child)
        if not isCurrent() then return end
        if child == currentFoundFrame then
            currentFoundFrame = nil
            currentFoundUUID  = nil
        end
    end)

    dprint("Script ter-inject. Listen folder:", notifyFolder:GetFullName())

    -- Passive retry loop (FIX BUG #2)
    if AutoConfig.AutoRetryWhileActive then
        task.spawn(function()
            while isCurrent() do
                task.wait(AutoConfig.AutoRetryInterval)
                if isAutoRejoinActive
                   and currentFoundFrame and currentFoundFrame.Parent
                   and currentFoundUUID and currentFoundUUID ~= "" then
                    dprint("Passive retry: Auto ON & notif masih hidup -> rejoin lagi.")
                    doRejoinAndUpdateStatus("Auto retry")
                end
            end
            dprint("Passive retry loop berhenti (instance sudah bukan owner).")
        end)
    end
end


