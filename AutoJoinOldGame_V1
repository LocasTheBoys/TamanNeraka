local function resolveDefaultPosition(name)
    local m = UISizeConfig.EdgeMargin
    local presets = {
        TopLeft      = { anchor = Vector2.new(0, 0),     position = UDim2.new(0, m, 0, m) },
        LeftCenter   = { anchor = Vector2.new(0, 0.5),   position = UDim2.new(0, m, 0.5, 0) },
        BottomLeft   = { anchor = Vector2.new(0, 1),     position = UDim2.new(0, m, 1, -m) },
        TopRight     = { anchor = Vector2.new(1, 0),     position = UDim2.new(1, -m, 0, m) },
        RightCenter  = { anchor = Vector2.new(1, 0.5),   position = UDim2.new(1, -m, 0.5, 0) },
        BottomRight  = { anchor = Vector2.new(1, 1),     position = UDim2.new(1, -m, 1, -m) },
        Center       = { anchor = Vector2.new(0.5, 0.5), position = UDim2.new(0.5, 0, 0.5, 0) },
    }
    return presets[name] or presets.RightCenter
end


