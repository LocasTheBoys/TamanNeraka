-- ║       SINGLE-INSTANCE LOCK (FIX BUG #3)                   ║
-- ╚══════════════════════════════════════════════════════════╝
-- Generate ID unik buat instance ini.
local INSTANCE_ID = tostring(math.random(1, 1e9)) .. "_" .. tostring(os.time()) .. "_" .. tostring(tick())

local function isCurrent()
    return _G[SafetyConfig.GlobalKey] == INSTANCE_ID
end

local function killOldGuiIn(parent)
    if not parent then return end
    local ok, kids = pcall(function() return parent:GetChildren() end)
    if not ok or not kids then return end
    for _, gui in ipairs(kids) do
        if gui:IsA("ScreenGui") then
            local name = gui.Name or ""
            if string.sub(name, 1, #SafetyConfig.OldGuiNamePrefix) == SafetyConfig.OldGuiNamePrefix then
                pcall(function() gui:Destroy() end)
                dprint("Destroyed old GUI:", name)
            end
        end
    end
end

if SafetyConfig.KillOldInstanceOnExec then
    -- (1) Set ID baru DULU -> instance lama akan tahu mereka bukan owner lagi
    --     dan loop/connection mereka self-disconnect via isCurrent().
    _G[SafetyConfig.GlobalKey] = INSTANCE_ID

    -- (2) Destroy ScreenGui dari instance lama (V1/V2/V3/V4/V5 lama).
    killOldGuiIn(CoreGui)
    killOldGuiIn(PlayerGui)
    if typeof(gethui) == "function" then
        local okG, hui = pcall(gethui)
        if okG and hui then killOldGuiIn(hui) end
    end

    dprint("Single-instance lock aktif. INSTANCE_ID =", INSTANCE_ID)
else
    -- mode "boleh numpuk" - tetep set ID biar isCurrent gak ke-trigger salah.
    _G[SafetyConfig.GlobalKey] = INSTANCE_ID
end


