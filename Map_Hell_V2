-- Fungsi untuk mengeksekusi script
local function executeScripts(scripts)
    if not scripts or #scripts == 0 then return end
    
    for _, scriptUrl in ipairs(scripts) do
        local co = coroutine.create(function()
            -- Menambahkan pcall untuk keamanan jika link github mati/bermasalah
            local success, err = pcall(function()
                loadstring(game:HttpGet(scriptUrl))()
            end)
            
            if not success then
                warn("Gagal load script dari: " .. tostring(scriptUrl) .. "\nError: " .. tostring(err))
            end
        end)
        coroutine.resume(co)
    end
end

