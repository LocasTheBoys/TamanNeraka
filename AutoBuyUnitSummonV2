local function SetupAutoBanViaClick(shopMiddle)
    pcall(function()
        local itemsFolder = shopMiddle.UnitShop.Frame.Top.Items
        local retry = 0
        while #itemsFolder:GetChildren() <= 1 and retry < 10 do task.wait(0.5); retry = retry + 1 end

        for _, item in ipairs(itemsFolder:GetChildren()) do
            if string.find(item.Name, "unit_") then
                local rarity = GetExactRarity(item)
                local f1 = item:FindFirstChild("Frame")
                local imgColor = f1 and f1:FindFirstChild("ImageLabel")
                local f2 = imgColor and imgColor:FindFirstChild("Frame")
                local redX = f2 and f2:FindFirstChild("ImageLabel")
                
                if redX and rarity ~= "Unknown" then
                    local wantToDelete = Config.DeleteRarity[rarity] == true
                    local isCurrentlyDeleted = (math.floor(redX.ImageTransparency) == 0)
                    
                    if (wantToDelete and not isCurrentlyDeleted) or (not wantToDelete and isCurrentlyDeleted) then
                        VirtualClick(item)
                        task.wait(0.3) 
                    end
                end
            end
        end
    end)
end

