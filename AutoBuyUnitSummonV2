local function VirtualClick(guiObj)
    if not guiObj then return end
    local inset, _ = GuiService:GetGuiInset()
    local pos, size = guiObj.AbsolutePosition, guiObj.AbsoluteSize
    local cx, cy = pos.X + (size.X / 2), pos.Y + (size.Y / 2) + inset.Y 
    VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, true, game, 0); task.wait(0.1)
    VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, false, game, 0)
end

local function GetExactRarity(item)
    local rarity = "Unknown"
    pcall(function()
        if item:IsA("ImageButton") or item:IsA("ImageLabel") then
            local c3 = item.ImageColor3
            local r = math.floor(c3.R * 255 + 0.5); local g = math.floor(c3.G * 255 + 0.5); local b = math.floor(c3.B * 255 + 0.5)

            if math.abs(r - 171) <= 10 and math.abs(g - 171) <= 10 and math.abs(b - 171) <= 10 then rarity = "Common"
            elseif math.abs(r - 85) <= 10 and math.abs(g - 170) <= 10 and math.abs(b - 255) <= 10 then rarity = "Uncommon"
            elseif math.abs(r - 85) <= 10 and math.abs(g - 255) <= 10 and math.abs(b - 0) <= 10 then rarity = "Rare"
            elseif math.abs(r - 255) <= 10 and math.abs(g - 170) <= 10 and math.abs(b - 0) <= 10 then rarity = "Epic"
            elseif math.abs(r - 255) <= 10 and math.abs(g - 0) <= 10 and math.abs(b - 0) <= 10 then rarity = "Legendary"
            elseif math.abs(r - 255) <= 10 and math.abs(g - 0) <= 10 and math.abs(b - 255) <= 10 then rarity = "Godly"
            end
        end
    end)
    return rarity
end

